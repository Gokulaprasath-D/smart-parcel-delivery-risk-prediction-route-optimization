43: const getRiskIcon = (level) => {
44:   let color = 'green';
45:   if (level === 'Medium') color = 'gold';
46:   if (level === 'High') color = 'red';
47: 
48:   return new L.Icon({
49:     iconUrl: `https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-${color}.png`,
50:     shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
51:     iconSize: [25, 41],
52:     iconAnchor: [12, 41],
53:     popupAnchor: [1, -34],
54:     shadowSize: [41, 41],
55:   });
56: };
57: 
58: const WeatherIcon = ({ condition, size = 14 }) => {
59:   if (condition === 0) return <Sun size={size} className="text-amber-400" />;
60:   if (condition === 1) return <CloudRain size={size} className="text-blue-400" />;
61:   return <CloudSnow size={size} className="text-slate-300" />;
62: };
63: 
64: const weatherLabel = (w) => {
65:   if (w === 0) return 'Clear';
66:   if (w === 1) return 'Rainy';
67:   return 'Stormy';
68: };
