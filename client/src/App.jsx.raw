31: // Fix for default Leaflet marker icons
32: import markerIcon2x from 'leaflet/dist/images/marker-icon-2x.png';
33: import markerIcon from 'leaflet/dist/images/marker-icon.png';
34: import markerShadow from 'leaflet/dist/images/marker-shadow.png';
35: 
36: delete L.Icon.Default.prototype._getIconUrl;
37: L.Icon.Default.mergeOptions({
38:   iconRetinaUrl: markerIcon2x,
39:   iconUrl: markerIcon,
40:   shadowUrl: markerShadow,
41: });
