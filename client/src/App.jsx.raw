70: const AnimatedNumber = ({ value, suffix = '' }) => (
71:   <motion.span
72:     key={value}
73:     initial={{ opacity: 0, y: 10 }}
74:     animate={{ opacity: 1, y: 0 }}
75:     className="tabular-nums font-bold"
76:   >
77:     {value}{suffix}
78:   </motion.span>
79: );
80: 
81: const getCompletedIcon = () => {
82:   return new L.Icon({
83:     iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-green.png',
84:     shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
85:     iconSize: [25, 41],
86:     iconAnchor: [12, 41],
87:     popupAnchor: [1, -34],
88:     shadowSize: [41, 41],
89:   });
90: };
