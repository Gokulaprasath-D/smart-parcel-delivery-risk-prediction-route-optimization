92: const calculateDistance = (lat1, lon1, lat2, lon2) => {
93:   const R = 6371e3; // metres
94:   const p1 = lat1 * Math.PI/180;
95:   const p2 = lat2 * Math.PI/180;
96:   const dp = (lat2-lat1) * Math.PI/180;
97:   const dl = (lon2-lon1) * Math.PI/180;
98: 
99:   const a = Math.sin(dp/2) * Math.sin(dp/2) +
100:             Math.cos(p1) * Math.cos(p2) *
101:             Math.sin(dl/2) * Math.sin(dl/2);
102:   const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
103:   return R * c;
104: };
